material:
    raytracer::ShapeDescriptor descriptor;

    // Init the material
    if (!node.exists("name"))
        throw utils::exception::CustomException(utils::exception::Error, utils::exception::Code::Parse, "The name field isn't defined for the material");
    std::string name = node["name"];
    std::transform(name.begin(), name.end(), name.begin(), ::tolower);
    material = this->factory<raytracer::IMaterial>(name + "_" + std::to_string(MATERIAL));

    // Other settings
    if (node.exists("color")) {
        const libconfig::Setting& color = node["color"];
        material.setColor({color[0], color[1], color[2]});
    }

    float transparency = 0.f;
    if (node.lookupValue("transparency", transparency))
        material.setTransparency(transparency);
    
    float reflection = 0.f;
    if (node.lookupValue("reflection", reflection))
        material.setReflection(reflection);
    
    bool mirror = false;
    if (node.lookupValue("is_mirror", mirror))
        material.setMirror(mirror);

camera:
    // Setup the cframe
    setCFrame(descriptor, node);

    // Other settings
    if (!node.exists("resolution"))
        throw utils::exception::CustomException(utils::exception::Error, utils::exception::Code::Parse, "The resolution field isn't defined for the camera");
    const libconfig::Setting& res = node["resolution"];
    this->_camera.setResolution({res[0], res[1]});

    float fieldOfView = 70.0f;
    if (node.lookupValue("fieldOfView", fieldOfView))
        this->_camera.setFieldOfView(fieldOfView);

light:
    // Setup the cframe
    setCFrame(descriptor, node["position"], node["orientation"]);

    // Other settings
    float intensity = 1.0f;
    node.lookupValue("intensity", intensity);

    const libconfig::Setting& color = node["color"];


object:
    // Get the object material
    descriptor.material = parseMaterial(node["material"]);

    // Setup the cframe
    setCFrame(descriptor, node);

    // Other settings
    const libconfig::Setting& dim = node["dimension"];
    descriptor.dimension.x = dim[0];
    descriptor.dimension.y = dim[1];

    float radius = 0.0f;
    mat.lookupValue("radius", radius);
    descriptor.radius = radius;
